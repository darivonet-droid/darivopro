# ═══════════════════════════════════════════════════════════════
# DARIVO PRO — Variables de entorno · Template
# NUNCA commitear valores reales — solo placeholders aquí
# ═══════════════════════════════════════════════════════════════

# ─── FRONTEND  →  frontend/.env.local ───────────────────────
# supabase.com > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Comunicación interna Next.js ↔ FastAPI
BACKEND_URL=http://localhost:8000
SERVICE_KEY=genera_una_clave_segura_min_32_chars

# Anthropic (solo server — route /api/ia/presupuesto)
ANTHROPIC_API_KEY=sk-ant-...

# ─── BACKEND  →  backend/.env ───────────────────────────────
# Service role (solo backend, NUNCA al browser)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...SERVICE_ROLE...

# WhatsApp Meta Cloud API
WA_PHONE_NUMBER_ID=123456789012345
WA_ACCESS_TOKEN=EAABsbCS...
WA_VERIFY_TOKEN=darivo_webhook_verify_token_seguro

# Clave compartida (misma que en frontend)
SERVICE_KEY=genera_una_clave_segura_min_32_chars

# ─── CI / Deploy ────────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_DB_PASSWORD=tu_password_db
RAILWAY_TOKEN=tu_railway_token
