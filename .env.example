# ═══════════════════════════════════════════════════════════
# DARIVO PRO — Variables de entorno
# Copiar a .env.local (frontend) y .env (backend)
# NUNCA commitear este archivo con valores reales
# ═══════════════════════════════════════════════════════════

# ─── FRONTEND (.env.local) ──────────────────────────────────
# Supabase — obtener en supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Backend URL (dev: localhost, prod: tu Railway/Render URL)
BACKEND_URL=http://localhost:8000

# Clave compartida entre Next.js y FastAPI (generar aleatoria)
SERVICE_KEY=genera_una_clave_segura_aqui_min_32_chars

# ─── BACKEND (.env) ──────────────────────────────────────────
# Supabase Service Role (solo backend, NUNCA al frontend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...SERVICE_ROLE...

# WhatsApp Meta Cloud API
# Obtener en: developers.facebook.com > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=123456789012345
WA_ACCESS_TOKEN=EAABsbCS...
WA_VERIFY_TOKEN=darivo_webhook_verify_token_seguro

# Clave compartida (igual que en frontend)
SERVICE_KEY=genera_una_clave_segura_aqui_min_32_chars

# ─── SUPABASE CLI ────────────────────────────────────────────
# Para GitHub Actions y migraciones
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_DB_PASSWORD=tu_password_db

# ─── RAILWAY (deploy backend) ────────────────────────────────
RAILWAY_TOKEN=tu_railway_token
