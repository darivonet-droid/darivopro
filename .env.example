# Frontend (Next.js)
#   cd frontend
#   cp .env.example .env.local
#   → editar frontend/.env.local

# Backend (FastAPI)
#   cd backend
#   cp .env.example .env
#   → editar backend/.env

# CI / Deploy (solo GitHub Secrets o panel de deploy)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
# RAILWAY_TOKEN=

# Migraciones pendientes en Supabase SQL Editor:
#   001_initial.sql … 005_plan_limits.sql (plan_tipo + ia_uso_diario)

# Vercel: frontend/ como root, dominio darivo.net
# Railway: backend/ con BACKEND_URL apuntando al servicio
