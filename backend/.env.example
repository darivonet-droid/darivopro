# ═══════════════════════════════════════════════════════════════
# DARIVO PRO — Backend (FastAPI)
# Copiar este archivo a .env y completar con tus keys reales:
#   cp .env.example .env
# NUNCA commitear .env
# ═══════════════════════════════════════════════════════════════

# supabase.com > Project > Settings > API (service_role)
SUPABASE_URL=https://tu-project-id.supabase.co
SUPABASE_SERVICE_KEY=

# WhatsApp Meta Cloud API
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=darivo_verify

# Clave compartida (legacy — el frontend ya no depende del backend)
SERVICE_KEY=

# CORS (opcional, separado por comas)
# ALLOWED_ORIGINS=http://localhost:3000,https://darivo.net,https://www.darivo.net
