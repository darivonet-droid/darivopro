# ═══════════════════════════════════════════════════════════════
# DARIVO PRO — Frontend (Next.js)
# Copiar a .env.local:  cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════

# Supabase (supabase.com > Project > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PDF y WhatsApp: resueltos en Next.js (app/api/pdf/* y enlace wa.me directo)

# Acceso multi-producto (Tarea 11 — allowlist server)
# Emails separados por coma, minúsculas opcionales
DARIVO_ADMIN_EMAILS=
DARIVO_PARTNER_EMAILS=

DLOCALGO_API_KEY=
DLOCALGO_API_SECRET=
DLOCALGO_SANDBOX=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Plan tokens suscripción (opcional — dashboard dLocal Go)
DLOCALGO_PLAN_BASICO_MENSUAL=
DLOCALGO_PLAN_BASICO_ANUAL=
DLOCALGO_PLAN_PRO_MENSUAL=
DLOCALGO_PLAN_PRO_ANUAL=
DLOCALGO_PLAN_BUSINESS_MENSUAL=
DLOCALGO_PLAN_BUSINESS_ANUAL=
# Secreto compartido webhook (recomendado producción — header Authorization: Bearer ...)
DLOCALGO_WEBHOOK_SECRET=

# Google Maps Places Autocomplete (campo Dirección — Clientes/Nueva factura)
# Sin esta key el campo funciona como texto libre normal, sin sugerencias.
# Generar en Google Cloud Console: habilitar "Places API", crear API key,
# restringirla por referrer (HTTP referrers) a darivopro.com/*.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# IA (solo server — OpenAI API oficial · 08 §5.2)
OPENAI_API_KEY=
# Opcional: gpt-4o-mini (default) · gpt-4o para visión Cierre
OPENAI_MODEL=
OPENAI_VISION_MODEL=

# Latitude Telemetry (traza las llamadas a OpenAI: Darivo, IA Cotización, IA Gasto)
# API key: Latitude → Settings → API Keys. Sin estas 2 variables, la app funciona
# igual, simplemente no se genera ninguna traza (lib/latitude.ts es no-op sin ellas).
LATITUDE_API_KEY=
LATITUDE_PROJECT_SLUG=

# Email transaccional (Gmail API, domain-wide delegation — frontend/src/lib/email/)
# JSON completo de la cuenta de servicio de Google Cloud, como string de una sola línea.
# Setup manual pendiente (Workspace + Cloud Console) — ver gmail-client.ts.
GMAIL_SERVICE_ACCOUNT_JSON=
# Opcional — default darivopro.com (info@, facturacion@, noreply@, partners@, soporte@)
EMAIL_DOMINIO=
# Secreto del webhook de Supabase Database Webhooks (comisión ganada Partner)
SUPABASE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════
# DEPLOY VERCEL (darivopro.com)
# ═══════════════════════════════════════════════════════════════
# 1. Importar repo → Root Directory: frontend
# 2. Variables de entorno (Production + Preview):
#    NEXT_PUBLIC_SUPABASE_URL
#    NEXT_PUBLIC_SUPABASE_ANON_KEY
#    SUPABASE_SERVICE_ROLE_KEY
#    OPENAI_API_KEY
#    DLOCALGO_API_KEY
#    DLOCALGO_API_SECRET
#    NEXT_PUBLIC_APP_URL
#    GMAIL_SERVICE_ACCOUNT_JSON
#    SUPABASE_WEBHOOK_SECRET
#    NEXT_PUBLIC_GOOGLE_MAPS_API_KEY (opcional — sin ella, Dirección es texto libre)
#    LATITUDE_API_KEY / LATITUDE_PROJECT_SLUG (opcional — sin ellas, no hay trazas)
# 3. Dominio: darivopro.com → Vercel > Settings > Domains
# 4. Build: npm run build  |  Output: .next (default)
# 5. Antes de lanzar: probar en Android Chrome + Lighthouse móvil >80
