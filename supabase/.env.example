# Supabase CLI — migraciones locales (supabase link + db push)
# Copiar a supabase/.env y rellenar (NO commitear .env)
#
# SUPABASE_ACCESS_TOKEN → https://supabase.com/dashboard/account/tokens
# SUPABASE_DB_PASSWORD  → Project Settings → Database (misma que GitHub secret)
# SUPABASE_PROJECT_REF  → ref del proyecto (producción: vyrtokggypcmpforglch)

SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=
